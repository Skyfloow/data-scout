PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Storage
DATA_DIR=./data

# Firecrawl API
FIRECRAWL_API_KEY=your_api_key_here

# Etsy anti-bot mode
ETSY_FORCE_FIRECRAWL=false

# Human-like delays for Playwright stealth mode
HUMAN_DELAY_MIN_MS=400
HUMAN_DELAY_MAX_MS=1200

# Google Gemini API (Fallback Extractor)
GEMINI_API_KEY=your_gemini_api_key_here
